{
  "name": "sap-hubspot-connector",
  "version": "1.0.0",
  "description": "Conector bidireccional entre SAP y HubSpot ",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "dev": "npx nodemon src/server.js",
    "start": "NODE_ENV=production node src/app.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "migrate:create": "npx migrate-mongo -f migrate-mongo-config.cjs create",
    "migrate:status": "npx migrate-mongo -f migrate-mongo-config.cjs status",
    "migrate:up": "npx migrate-mongo -f migrate-mongo-config.cjs up",
    "migrate:down": "npx migrate-mongo -f migrate-mongo-config.cjs down"
  },
  "keywords": [],
  "author": "Ing. Alejandro Salas",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.2",
    "dotenv": "^16.4.5",
    "fastify": "^4.29.1",
    "mongoose": "^8.21.0",
    "node-cron": "^4.2.1",
    "nodemon": "^3.1.11",
    "tedious": "^18.6.1",
    "winston": "^3.14.2",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "jest": "^30.1.3",
    "mongodb-memory-server": "^10.2.3",
    "supertest": "^7.1.4"
  }
}
