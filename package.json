{
  "name": "sap-hubspot-connector",
  "version": "2.1.25",
  "description": "Conector bidireccional entre SAP y HubSpot ",
  "main": "src/main/app.js",
  "type": "module",
  "imports": {
    "#application/*": "./src/application/*",
    "#bootstrap/*": "./src/bootstrap/*",
    "#domain/*": "./src/domain/*",
    "#infrastructure/*": "./src/infrastructure/*",
    "#interfaces/*": "./src/interfaces/*",
    "#main/*": "./src/main/*",
    "#ports/*": "./src/ports/*",
    "#shared/*": "./src/shared/*",
    "#composition/*": "./src/composition/*",
    "#plugins/*": "./src/plugins/*"
  },
  "scripts": {
    "dev": "npx nodemon src/main/server.js",
    "dev:all": "bash -lc 'trap \"kill 0\" EXIT INT TERM; npm run dev & npm run dev:worker & wait'",
    "start": "NODE_ENV=production node src/main/server.js",
    "start:api": "NODE_ENV=production node src/main/server.js",
    "start:worker": "NODE_ENV=production node src/main/worker.js",
    "dev:worker": "npx nodemon src/main/worker.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "migrate:create": "npx migrate-mongo -f migrate-mongo-config.cjs create",
    "migrate:status": "npx migrate-mongo -f migrate-mongo-config.cjs status",
    "migrate:up": "npx migrate-mongo -f migrate-mongo-config.cjs up",
    "migrate:down": "npx migrate-mongo -f migrate-mongo-config.cjs down"
  },
  "keywords": [],
  "author": "Ing. Alejandro Salas",
  "license": "ISC",
  "dependencies": {
    "@bull-board/api": "^5.21.5",
    "@bull-board/fastify": "^5.21.5",
    "axios": "^1.13.2",
    "bullmq": "^5.71.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.29.1",
    "ioredis": "^5.10.1",
    "mongoose": "^8.21.0",
    "node-cron": "^4.2.1",
    "nodemon": "^3.1.11",
    "redis": "^4.7.1",
    "tedious": "^18.6.1",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "jest": "^30.1.3",
    "mongodb-memory-server": "^10.2.3",
    "supertest": "^7.1.4"
  }
}
