# ─── SAP – campos adicionales por entidad ────────────────────────────────────
COMPANY_ADD_FIELDS_URL_SAP=ContactEmployees,BPAddresses
PRODUCT_ADD_FIELDS_URL_SAP=ItemWarehouseInfoCollection,ItemPrices
DEAL_ADD_FIELDS_URL_SAP=

# ─── Cron jobs ────────────────────────────────────────────────────────────────
SAP_SYNC_CRON_ENABLED=false
WEBHOOK_PROCESSOR_CRON_ENABLED=false

# ─── SAP Sync queue / worker ──────────────────────────────────────────────────
SAP_SYNC_JOB_ATTEMPTS=20
SAP_SYNC_JOB_BACKOFF_MS=15000
SAP_SYNC_REMOVE_ON_COMPLETE=100
SAP_SYNC_REMOVE_ON_FAIL=500
SAP_SYNC_WORKER_CONCURRENCY=5
SAP_SYNC_TENANT_LOCK_TTL_MS=600000

# ─── Webhook queue / worker ───────────────────────────────────────────────────
WEBHOOK_JOB_ATTEMPTS=1
WEBHOOK_JOB_BACKOFF_MS=15000
WEBHOOK_REMOVE_ON_COMPLETE=100
WEBHOOK_REMOVE_ON_FAIL=500
WEBHOOK_WORKER_CONCURRENCY=5
WEBHOOK_EVENT_BATCH_SIZE=10
WEBHOOK_EVENT_MAX_RETRIES=3

# ─── Bull Board ───────────────────────────────────────────────────────────────
BULL_BOARD_PATH=/bull-board
